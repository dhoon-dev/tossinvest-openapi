TOSSINVEST_ENABLE_LIVE_TESTS=false
TOSSINVEST_API_KEY=
TOSSINVEST_SECRET_KEY=

# Optional live-test settings.
# TOSSINVEST_ACCOUNT is an accountSeq from /api/v1/accounts, not an email.
# Leave it empty to let live tests use the first account returned by the API.
TOSSINVEST_ACCOUNT=
TOSSINVEST_LIVE_SYMBOL=005930
TOSSINVEST_LIVE_CURRENCY=KRW
TOSSINVEST_BASE_URL=https://openapi.tossinvest.com

# Live order tests are not included by default. If they are added later, keep
# them behind this separate opt-in flag.
TOSSINVEST_ENABLE_LIVE_ORDER=false
